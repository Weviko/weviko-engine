# Crawl target
WEVIKO_TARGET_URL=https://www.weviko.com
WEVIKO_PRODUCT_PATH_HINT=/part/
WEVIKO_DISCOVERY_EXTRA_PATH_HINTS=
WEVIKO_ROUTE_WATCH_HINTS=/parts,/dashboard
WEVIKO_DISCOVERY_MAX_PAGES=12
WEVIKO_DISCOVERY_MAX_MATCHES=20
WEVIKO_DISCOVERY_MAX_DEPTH=2
WEVIKO_NUM_WORKERS=3
WEVIKO_HEADLESS=true
WEVIKO_BLOCKED_RESOURCE_TYPES=image,media,font,stylesheet
WEVIKO_MARKDOWN_LIMIT=8000
WEVIKO_FALLBACK_TEXT_CHARS=1500
WEVIKO_COMPRESSED_TEXT_CHARS=2000
WEVIKO_COMPRESSION_CONTEXT_LINES=1

# Optional Supabase persistence
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=
WEVIKO_CACHE_TABLE=crawling_logs
WEVIKO_PARTS_TABLE=parts
WEVIKO_PROMPTS_TABLE=system_prompts
WEVIKO_REVIEW_TABLE=review_decisions
WEVIKO_TRANSLATIONS_TABLE=part_translations
WEVIKO_VISION_TABLE=vision_analysis
WEVIKO_PENDING_TABLE=pending_data
WEVIKO_CONFIGS_TABLE=configs
WEVIKO_DEAD_LETTERS_TABLE=dead_letters
WEVIKO_PROMPTS_FILE=prompt_templates.json

# Optional Gemini extraction
GOOGLE_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.5-pro

# Optional proxy
PLAYWRIGHT_PROXY_SERVER=
PLAYWRIGHT_PROXY_USERNAME=
PLAYWRIGHT_PROXY_PASSWORD=
