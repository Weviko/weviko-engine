{
  "manifest_version": 3,
  "name": "Weviko Live Capture",
  "version": "1.0.0",
  "description": "Send the current tab to the local Weviko live capture server.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*"
  ],
  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Weviko Capture",
    "default_popup": "popup.html"
  }
}
